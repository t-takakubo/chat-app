# Base URL of the Worker that serves /match and /room/* (see worker/).
# Only needed for local dev, where the Vite dev server (pnpm run dev) and the
# Worker (pnpm run worker:dev) run as separate processes. In production the
# frontend and the Worker are the same deployment, so this should be unset —
# the app falls back to same-origin automatically.
VITE_MATCH_WORKER_URL=http://localhost:8787
